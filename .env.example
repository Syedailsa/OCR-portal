APP_URL=https://ocr-portal.27.jugaar.ai
API_URL=https://api.ocr-portal.27.jugaar.ai
CORS_ORIGIN=https://ocr-portal.27.jugaar.ai

POSTGRES_DB=ocr_portal
POSTGRES_USER=ocr_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ocr_user:change-me@postgres:5432/ocr_portal

# Optional. Set this only if you enable background queue mode.
# For Upstash, use the provided rediss:// URL.
REDIS_URL=
QUEUE_MODE=inline

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

OCR_ENGINE=paddleocr
MAX_UPLOAD_MB=20
OCR_MAX_PAGES=20
OCR_TIMEOUT_SECONDS=300

UPLOAD_DIR=/data/uploads
EXPORT_DIR=/data/exports
SEARCH_ENGINE=postgres
LOG_LEVEL=info
